## Bước 4: Cài đặt Deploy API (Node.js Express)

Deploy API là một web server nhỏ chạy trên Rocky 9, có nhiệm vụ **nhận HTTP request từ Teams Bot** và **gọi shell script deploy**.

### 4.1. Khởi tạo project Node.js

```bash
# Chuyển sang user deploy
sudo su - deploy
cd /opt/deploy-api

# Khởi tạo package.json
npm init -y

# Cài Express và dotenv
npm install express dotenv
```

### 4.2. Tạo file cấu hình môi trường

```bash
cat > /opt/deploy-api/.env << 'EOF'
# Port mà Deploy API lắng nghe
PORT=9000

# Token bí mật - Teams Bot phải gửi đúng token này mới được phép deploy
# ĐỔI THÀNH CHUỖI DÀI, KHÓ ĐOÁN, VÍ DỤ: openssl rand -hex 32
DEPLOY_SECRET=doi-thanh-chuoi-bi-mat-cua-ban

# Đường dẫn tới shell script deploy
DEPLOY_SCRIPT=/opt/deploy/deploy.sh
EOF
```

> [!WARNING]
> **Bắt buộc** phải đổi giá trị `DEPLOY_SECRET` thành một chuỗi ngẫu nhiên dài. Tạo nhanh bằng lệnh:
> ```bash
> openssl rand -hex 32
> ```
> Ví dụ kết quả: `a1b2c3d4e5f6...` (64 ký tự hex). Copy chuỗi đó paste vào thay thế `doi-thanh-chuoi-bi-mat-cua-ban`.

### 4.3. Tạo file server chính `/opt/deploy-api/server.js`

```bash
cat > /opt/deploy-api/server.js << 'ENDOFFILE'
require("dotenv").config();
const express = require("express");
const { spawn } = require("child_process");

const app = express();
app.use(express.json());

const port = Number(process.env.PORT || 9000);
const deploySecret = process.env.DEPLOY_SECRET;
const deployScript = process.env.DEPLOY_SCRIPT || "/opt/deploy/deploy.sh";
const allowedTargets = new Set(["api", "website", "all"]);

// Endpoint kiểm tra API có sống không
app.get("/health", (req, res) => {
  res.json({ ok: true, message: "Deploy API is running" });
});

// Endpoint nhận lệnh deploy
app.post("/deploy", (req, res) => {
  // 1. Kiểm tra Bearer Token
  const auth = req.headers.authorization || "";
  const token = auth.replace(/^Bearer\s+/i, "").trim();

  if (!deploySecret || token !== deploySecret) {
    console.log(`[${new Date().toISOString()}] Từ chối: Sai token`);
    return res.status(401).json({ ok: false, message: "Unauthorized" });
  }

  // 2. Kiểm tra target hợp lệ
  const target = String(req.body.target || "").trim().toLowerCase();
  if (!allowedTargets.has(target)) {
    return res.status(400).json({
      ok: false,
      message: "Target không hợp lệ. Chỉ chấp nhận: api, website, all",
    });
  }

  const requestedBy = String(req.body.requested_by || "unknown").trim();
  console.log(`[${new Date().toISOString()}] Deploy [${target}] yêu cầu bởi: ${requestedBy}`);

  // 3. Chạy script deploy (spawn không dùng shell: true để tránh injection)
  const startedAt = Date.now();
  const child = spawn(deployScript, [target], { shell: false });

  let output = "";
  child.stdout.on("data", (data) => { output += data.toString(); });
  child.stderr.on("data", (data) => { output += data.toString(); });

  child.on("close", (code) => {
    const durationSeconds = Math.round((Date.now() - startedAt) / 1000);
    const commitMatch = output.match(/Commit:\s*([a-f0-9]+)/i);
    const commit = commitMatch ? commitMatch[1] : null;

    // Thành công
    if (code === 0) {
      return res.json({
        ok: true, target, commit,
        duration_seconds: durationSeconds,
        message: "Deploy thành công",
      });
    }

    // Đang có deploy khác chạy (exit code 20)
    if (code === 20) {
      return res.status(409).json({
        ok: false, target,
        message: "Đang có một phiên deploy khác đang chạy. Vui lòng thử lại sau.",
      });
    }

    // Lỗi khác
    return res.status(500).json({
      ok: false, target,
      duration_seconds: durationSeconds,
      message: "Deploy thất bại",
      exit_code: code,
    });
  });
});

app.listen(port, () => {
  console.log(`Deploy API đang chạy tại port ${port}`);
});
ENDOFFILE
```

