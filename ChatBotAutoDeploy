## Bước 6: Viết code xử lý Bot (Node.js)

### 6.1. Tóm tắt Bot hoạt động thế nào

```text
Teams gửi tin nhắn → Microsoft Cloud → POST tới Bot server của bạn
                                          → Bot xử lý lệnh
                                          → Gọi Deploy API trên Rocky 9
                                          → Trả kết quả về Teams
```

Bot server có thể chạy ở:
- **Cùng server Rocky 9** (đơn giản nhất)
- **Một VPS/cloud riêng** (Azure App Service, AWS, DigitalOcean...)
- **Azure App Service Free Tier** (miễn phí cho bot nhỏ)

### 6.2. Khởi tạo project Bot

```bash
# Tạo thư mục project (trên server hoặc máy dev)
mkdir -p /opt/teams-bot
cd /opt/teams-bot

# Khởi tạo
npm init -y

# Cài các package cần thiết
npm install botbuilder botframework-connector dotenv node-fetch@2
```

### 6.3. Tạo file `.env` cho Bot

```bash
cat > /opt/teams-bot/.env << 'EOF'
# Azure Bot credentials (lấy từ Bước 5.2)
MICROSOFT_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MICROSOFT_APP_PASSWORD=chuoi-secret-tu-azure

# URL Deploy API trên server Rocky 9 (lấy từ Bước 4)
DEPLOY_API_URL=https://deploy.your-domain.com/deploy
DEPLOY_SECRET=doi-thanh-chuoi-bi-mat-cua-ban

# Danh sách email được phép deploy (cách nhau bằng dấu phẩy)
WHITELIST_USERS=admin@example.com,devops@example.com,techlead@example.com

# Port cho Bot server
PORT=3978
EOF
```

### 6.4. Tạo file `index.js` — Code xử lý chính của Bot

```bash
cat > /opt/teams-bot/index.js << 'ENDOFFILE'
require("dotenv").config();
const { BotFrameworkAdapter, TurnContext } = require("botbuilder");
const http = require("http");
const fetch = require("node-fetch");

// ===================== CẤU HÌNH =====================

const adapter = new BotFrameworkAdapter({
  appId: process.env.MICROSOFT_APP_ID,
  appPassword: process.env.MICROSOFT_APP_PASSWORD,
});

const DEPLOY_API_URL = process.env.DEPLOY_API_URL;
const DEPLOY_SECRET = process.env.DEPLOY_SECRET;
const WHITELIST = (process.env.WHITELIST_USERS || "")
  .split(",")
  .map((e) => e.trim().toLowerCase())
  .filter(Boolean);
const PORT = Number(process.env.PORT || 3978);

// Lưu các lệnh deploy đang chờ (key = conversationId)
const pendingDeploys = new Map();

// ===================== XỬ LÝ TIN NHẮN =====================

adapter.onTurnError = async (context, error) => {
  console.error("[Bot Error]", error);
  await context.sendActivity("Đã xảy ra lỗi nội bộ. Vui lòng thử lại sau.");
};

async function handleMessage(context) {
  // 1. Lấy nội dung tin nhắn (bỏ phần @mention)
  const rawText = TurnContext.removeRecipientMention(context.activity) || "";
  const text = rawText.trim().toLowerCase();
  const userEmail = (
    context.activity.from.aadObjectId
      ? context.activity.from.userPrincipalName || context.activity.from.name
      : context.activity.from.name || "unknown"
  ).toLowerCase();
  const conversationId = context.activity.conversation.id;

  console.log(`[${new Date().toISOString()}] Nhận lệnh: "${text}" từ: ${userEmail}`);

  // 2. Parse lệnh
  if (text === "cancel") {
    return handleCancel(context, conversationId, userEmail);
  }

  if (text === "status") {
    return handleStatus(context, conversationId);
  }

  const deployMatch = text.match(/^deploy\s+(api|website|all)$/);
  if (!deployMatch) {
    return context.sendActivity(
      "❓ **Lệnh không hợp lệ.**\n\n" +
      "Các lệnh được hỗ trợ:\n" +
      "- `deploy api` — Triển khai dịch vụ API\n" +
      "- `deploy website` — Triển khai dịch vụ Website\n" +
      "- `deploy all` — Triển khai toàn bộ\n" +
      "- `status` — Kiểm tra trạng thái\n" +
      "- `cancel` — Hủy lệnh deploy đang chờ"
    );
  }

  const target = deployMatch[1];

  // 3. Kiểm tra quyền
  if (!WHITELIST.includes(userEmail)) {
    return context.sendActivity(
      `🚫 **Từ chối truy cập.**\n\nTài khoản \`${userEmail}\` không có quyền thực hiện deploy.`
    );
  }

  // 4. Kiểm tra đã có lệnh đang chờ chưa
  if (pendingDeploys.has(conversationId)) {
    return context.sendActivity(
      "⏳ Đã có một lệnh deploy đang trong thời gian chờ. " +
      "Gõ `cancel` để hủy lệnh cũ trước khi tạo lệnh mới."
    );
  }

  // 5. Thông báo và bắt đầu đếm ngược 2 phút
  await context.sendActivity(
    `⏱️ **Lệnh \`deploy ${target}\` sẽ tự động bắt đầu sau 2 phút.**\n\n` +
    `- Người yêu cầu: \`${userEmail}\`\n` +
    `- Gõ \`@DeployBot cancel\` để hủy nếu cần.\n\n` +
    `⚠️ *Vui lòng tạm dừng thao tác trên production trong thời gian này.*`
  );

  // 6. Đặt timer 120 giây
  const timer = setTimeout(async () => {
    pendingDeploys.delete(conversationId);

    // Gọi Deploy API
    try {
      await context.sendActivity(`🚀 Hết thời gian chờ. Đang tiến hành deploy **${target}**...`);

      const response = await fetch(DEPLOY_API_URL, {
        method: "POST",
        headers: {
          "Authorization": `Bearer ${DEPLOY_SECRET}`,
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          target: target,
          requested_by: userEmail,
          source: "microsoft-teams",
        }),
      });

      const result = await response.json();

      if (result.ok) {
        await context.sendActivity(
          `✅ **Deploy thành công!**\n\n` +
          `- Dịch vụ: \`${result.target}\`\n` +
          `- Commit: \`${result.commit || "N/A"}\`\n` +
          `- Thời gian: ${result.duration_seconds}s\n` +
          `- Người yêu cầu: \`${userEmail}\``
        );
      } else {
        await context.sendActivity(
          `❌ **Deploy thất bại!**\n\n` +
          `- Dịch vụ: \`${target}\`\n` +
          `- Lý do: ${result.message}\n` +
          `- Người yêu cầu: \`${userEmail}\`\n\n` +
          `Vui lòng kiểm tra log trên server.`
        );
      }
    } catch (err) {
      console.error("[Deploy Error]", err);
      await context.sendActivity(
        `❌ **Không thể kết nối tới Deploy API.**\n\n` +
        `Lỗi: ${err.message}\n\n` +
        `Vui lòng kiểm tra server Rocky 9 có đang chạy không.`
      );
    }
  }, 120_000); // 120 giây = 2 phút

  pendingDeploys.set(conversationId, { timer, target, userEmail });
}

// ===================== XỬ LÝ CANCEL =====================

async function handleCancel(context, conversationId, userEmail) {
  const pending = pendingDeploys.get(conversationId);

  if (!pending) {
    return context.sendActivity("ℹ️ Hiện không có lệnh deploy nào đang chờ để hủy.");
  }

  // Kiểm tra quyền cancel
  if (!WHITELIST.includes(userEmail)) {
    return context.sendActivity("🚫 Bạn không có quyền hủy lệnh deploy.");
  }

  clearTimeout(pending.timer);
  pendingDeploys.delete(conversationId);

  await context.sendActivity(
    `🛑 **Lệnh deploy đã được HỦY.**\n\n` +
    `- Lệnh bị hủy: \`deploy ${pending.target}\`\n` +
    `- Người hủy: \`${userEmail}\``
  );
}

// ===================== XỬ LÝ STATUS =====================

async function handleStatus(context, conversationId) {
  const pending = pendingDeploys.get(conversationId);

  if (pending) {
    return context.sendActivity(
      `⏳ **Đang có lệnh deploy chờ xử lý:**\n\n` +
      `- Dịch vụ: \`deploy ${pending.target}\`\n` +
      `- Người yêu cầu: \`${pending.userEmail}\`\n` +
      `- Gõ \`cancel\` để hủy.`
    );
  }

  return context.sendActivity("✅ Không có lệnh deploy nào đang chờ xử lý.");
}

// ===================== HTTP SERVER =====================

const server = http.createServer(async (req, res) => {
  if (req.method === "POST" && req.url === "/api/messages") {
    let body = "";
    req.on("data", (chunk) => { body += chunk; });
    req.on("end", async () => {
      try {
        const activity = JSON.parse(body);
        const authHeader = req.headers.authorization || "";

        await adapter.processActivity(
          { ...req, body: activity, headers: { ...req.headers, authorization: authHeader } },
          res,
          async (context) => {
            if (context.activity.type === "message") {
              await handleMessage(context);
            }
          }
        );
      } catch (err) {
        console.error("[Server Error]", err);
        res.writeHead(500);
        res.end("Internal Server Error");
      }
    });
  } else if (req.method === "GET" && req.url === "/health") {
    res.writeHead(200, { "Content-Type": "application/json" });
    res.end(JSON.stringify({ ok: true, message: "Bot is running" }));
  } else {
    res.writeHead(404);
    res.end("Not found");
  }
});

server.listen(PORT, () => {
  console.log(`Teams Bot Server đang chạy tại port ${PORT}`);
  console.log(`Messaging endpoint: http://localhost:${PORT}/api/messages`);
  console.log(`Whitelist: ${WHITELIST.join(", ")}`);
});
ENDOFFILE
```

> [!NOTE]
> **Giải thích code trên hoạt động thế nào:**
> 1. Teams gửi POST request tới `/api/messages` mỗi khi có người gõ tin nhắn mention bot
> 2. Bot đọc tin nhắn, bỏ phần `@DeployBot`, lấy phần lệnh (ví dụ `deploy all`)
> 3. Kiểm tra email người gửi có trong whitelist không
> 4. Nếu OK → Gửi thông báo "chờ 2 phút" → Đặt setTimeout 120 giây
> 5. Trong 2 phút đó, nếu ai gõ `cancel` → Hủy timer
> 6. Hết 2 phút không bị cancel → Gọi HTTP POST tới Deploy API trên Rocky 9
> 7. Nhận kết quả → Gửi tin nhắn kết quả về channel

### 6.5. Cài Bot chạy nền bằng systemd

```bash
sudo cat > /etc/systemd/system/teams-bot.service << 'EOF'
[Unit]
Description=Microsoft Teams Deploy Bot
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/teams-bot
EnvironmentFile=/opt/teams-bot/.env
ExecStart=/usr/bin/node /opt/teams-bot/index.js
Restart=always
RestartSec=5
User=deploy
Group=deploy

[Install]
WantedBy=multi-user.target
EOF

sudo systemctl daemon-reload
sudo systemctl enable teams-bot
sudo systemctl start teams-bot

# Kiểm tra
sudo systemctl status teams-bot
```

